@page "/Register"
@inject HttpClient Http


@using Control_Panel.Components.Models
@using Microsoft.AspNetCore.Authorization

<h3>Register</h3>

<div>
    <label>Email</label><br />
    <input @bind="model.Email" type="email" />
</div>

<div>
    <label>Contraseña</label><br />
    <input @bind="model.Password" type="password" />
</div>

<div>
    <label>Confirmar contraseña</label><br />
    <input @bind="model.ConfirmPassword" type="password" />
</div>

<br />

<button @onclick="RegisterUser">Registrar</button>

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

@code {

    private RegisterModel model = new();
    private string? message;

    private async Task RegisterUser()
    {
        // Validaciones básicas
        if (string.IsNullOrWhiteSpace(model.Email) ||
            string.IsNullOrWhiteSpace(model.Password))
        {
            message = "Todos los campos son obligatorios.";
            return;
        }

        if (model.Password != model.ConfirmPassword)
        {
            message = "Las contraseñas no coinciden.";
            return;
        }

        // Llamada al backend
        var response = await Http.PostAsJsonAsync("api/auth/register", model);

        if (response.IsSuccessStatusCode)
        {
            message = "Usuario registrado correctamente.";
        }
        else
        {
            message = "Error al registrar el usuario.";
        }
    }
    
}