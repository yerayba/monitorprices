
@page "/register"
@using System.ComponentModel.DataAnnotations
@using ControlPanel.Components.Models
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Registro</h3>

<EditForm Model="model"
          OnValidSubmit="RegisterAsync"
          FormName="RegisterForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Email</label>
        <InputText @bind-Value="model.Email" />
    </div>

    <div>
        <label>Password</label>
        <InputText type="password" @bind-Value="model.Password" />
    </div>

    <div>
        <label>Confirmar Password</label>
        <InputText type="password" @bind-Value="model.ConfirmPassword" />
    </div>

    <button type="submit">Registrarse</button>
</EditForm>

@code {
    
    private RegisterRequest model = new();

    private async Task RegisterAsync()
    {
        var response = await Http.PostAsJsonAsync("http://192.168.0.24:8080/auth/register", model);
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/login");
        }
    }
    
}