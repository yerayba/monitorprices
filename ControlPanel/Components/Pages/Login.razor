
@page "/login"
@using System.ComponentModel.DataAnnotations
@using ControlPanel.Components.Models
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Login</h3>

<EditForm Model="model"
          OnValidSubmit="LoginAsync"
          FormName="LoginForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Email</label>
        <InputText @bind-Value="model.Email"/>
    </div>

    <div>
        <label>Password</label>
        <InputText type="password" @bind-Value="model.Password"/>
    </div>

    <button type="submit">Entrar</button>
</EditForm>

<div class="mt-3">
    <NavLink href="/register">
        ¿No tienes cuenta? Regístrate
    </NavLink>
</div>

@code {
    private LoginRequest model = new();

    private async Task LoginAsync()
    {
        var response = await Http.PostAsJsonAsync("http://192.168.0.24:8080/auth/login", model);
        if (response.IsSuccessStatusCode)
        {
            var token = await response.Content.ReadAsStringAsync();
            // guardar token (localStorage / auth provider)
            Nav.NavigateTo("/");
        }
    }


    

}
